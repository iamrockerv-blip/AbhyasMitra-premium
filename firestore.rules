rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    // Check if request is from a signed-in user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user has admin custom claim
    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    // ─── products ───────────────────────────────────────────────────────────
    // Public read for published products, admin-only writes
    match /products/{productId} {
      // Anyone (even unauthenticated) can read published products
      allow read: if resource.data.published == true;
      // Authenticated users can read any product (for purchase verification)
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete products
      allow create, update, delete: if isAdmin();
    }

    // ─── purchases ──────────────────────────────────────────────────────────
    // Users can only read their OWN purchases.
    // ALL writes are done server-side via the Admin SDK (webhook & verify routes).
    // Direct client writes are completely blocked.
    match /purchases/{purchaseId} {
      // User can only read their own purchase documents
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // NO client writes allowed — only Admin SDK (server) can write
      allow write: if false;
    }

    // ─── admins ─────────────────────────────────────────────────────────────
    // Admin management collection — no client access at all.
    // Admin status is managed via Firebase custom claims (set via Admin SDK).
    match /admins/{adminId} {
      allow read, write: if false;
    }

    // ─── Default deny ───────────────────────────────────────────────────────
    // All other collections are denied by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
